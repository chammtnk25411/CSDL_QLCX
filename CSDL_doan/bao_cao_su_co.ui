   <string>Hệ thống Quản lý và Bảo tồn Thực vật</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QMainWindow { background-color: #f4f6f5; }
QWidget#sidebarFrame { background-color: #1e5631; }
QLabel#sidebarTitle { color: #ffffff; font-size: 12px; font-weight: bold; letter-spacing: 1px; }
QPushButton[class=&quot;navBtn&quot;] { text-align: left; padding: 10px 20px; color: #dfeee3; font-size: 13px; border: none; background-color: transparent; }
QPushButton[class=&quot;navBtn&quot;]:hover { background-color: #24693a; }
QPushButton#navActive { text-align: left; padding: 10px 20px; color: #ffffff; font-size: 13px; font-weight: bold; border: none; background-color: #2f7a45; border-left: 4px solid #ffffff; }
QWidget#headerFrame { background-color: #ffffff; border-bottom: 1px solid #e2e5e3; }
QLabel#headerTitle { font-size: 16px; font-weight: bold; color: #1e5631; }
QLabel#headerSubtitle { font-size: 11px; color: #7a8a7f; }
QLabel#pageTitle { font-size: 20px; font-weight: bold; color: #1c1c1c; }
QLineEdit#searchBox { border: 1px solid #d8dcd9; border-radius: 6px; padding: 8px 12px; font-size: 12px; background-color: #ffffff; }
QPushButton#btnAddSurvey { background-color: #1e5631; color: #ffffff; font-size: 12px; font-weight: bold; border-radius: 6px; padding: 10px 18px; }
QPushButton#btnAddSurvey:hover { background-color: #24693a; }
QTableWidget { background-color: #ffffff; border: 1px solid #e2e5e3; border-radius: 8px; gridline-color: #eef1ef; font-size: 12px; }
QHeaderView::section { background-color: #f7f9f7; color: #5c6b60; font-weight: bold; font-size: 11px; padding: 10px 6px; border: none; border-bottom: 1px solid #e2e5e3; }
QLabel#paginationInfo { color: #6b7a70; font-size: 12px; }
QPushButton.pageBtn { background-color: #ffffff; border: 1px solid #d8dcd9; border-radius: 5px; min-width: 28px; min-height: 28px; }
QPushButton#pageCurrent { background-color: #1e5631; color: #ffffff; border-radius: 5px; min-width: 28px; min-height: 28px; font-weight: bold; }
QLabel#userName { font-size: 12px; font-weight: bold; color: #1c1c1c; }
QLabel#userRole { font-size: 10px; color: #8a978d; }
QLabel#avatarLabel { background-color: #1e5631; color: #ffffff; border-radius: 18px; font-weight: bold; }
QLabel#logoCircle { background-color: #eef4ee; border-radius: 18px; }
QLabel#breadcrumb { font-size: 12px; color: #6b7a70; }
QLabel[class=&quot;formLabel&quot;] { font-size: 12px; font-weight: bold; color: #33413a; }
QLineEdit#fieldInput { border: 1px solid #d8dcd9; border-radius: 6px; padding: 9px 12px; font-size: 12px; background-color: #ffffff; color: #1c1c1c; }
QLineEdit#fieldInput:disabled { background-color: #f4f6f5; color: #9aa39d; }
QDateEdit, QDateTimeEdit { border: 1px solid #d8dcd9; border-radius: 6px; padding: 9px 12px; font-size: 12px; background-color: #ffffff; }
QComboBox#fieldCombo { border: 1px solid #d8dcd9; border-radius: 6px; padding: 9px 12px; font-size: 12px; background-color: #ffffff; }
QTextEdit#fieldTextArea { border: 1px solid #d8dcd9; border-radius: 6px; padding: 10px 12px; font-size: 12px; background-color: #ffffff; }
QLabel#charCounter { font-size: 11px; color: #9aa39d; }
QWidget#uploadDropzone { background-color: #fbfcfb; border: 2px dashed #d8dcd9; border-radius: 8px; }
QLabel#uploadHint { font-size: 12px; color: #8a978d; }
QLabel#uploadFormatHint { font-size: 11px; color: #9aa39d; }
QPushButton#btnChooseImage { border: 1px solid #d8dcd9; border-radius: 6px; padding: 8px 16px; font-size: 12px; background-color: #ffffff; color: #33413a; }
QPushButton#btnChooseImage:hover { background-color: #f4f6f5; }
QPushButton#btnCancel { border: 1px solid #d8dcd9; border-radius: 6px; padding: 10px 22px; font-size: 12px; font-weight: bold; background-color: #ffffff; color: #33413a; }
QPushButton#btnCancel:hover { background-color: #f4f6f5; }
QPushButton#btnSave { background-color: #1e5631; border: none; border-radius: 6px; padding: 10px 26px; font-size: 12px; font-weight: bold; color: #ffffff; }
QPushButton#btnSave:hover { background-color: #24693a; }
QLabel[class=&quot;requiredMark&quot;] { color: #e53935; font-size: 12px; font-weight: bold; }
QLabel[class=&quot;breadcrumbCurrent&quot;] { color: #1e5631; font-size: 12px; font-weight: bold; }
QLabel[class=&quot;breadcrumbText&quot;] { color: #6b7a70; font-size: 12px; }
QLabel[class=&quot;breadcrumbSep&quot;] { color: #a9b3ad; font-size: 12px; }
QScrollArea#formScrollArea { border: none; background-color: transparent; }
QWidget#scrollAreaWidgetContents { background-color: transparent; }
</string>
